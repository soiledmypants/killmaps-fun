# Copy to server/.env and fill in. server/.env is gitignored — NEVER commit real keys.
# Leave key/RPC values blank to run in MOCK mode (records ledger + txns, no transfers,
# token verification returns "unverified but playable").

NODE_ENV=production

# Render provides PORT automatically; for local dev the server defaults to 9001
# (Boss.fun/course-fun uses 8787 — keep them separate).
PORT=

# Persistent storage. REQUIRED in production (Render's disk is ephemeral and wipes
# the JSON file on every deploy/restart). Use a free managed Postgres — Neon,
# Supabase, or Render Postgres — and paste its connection string here.
# Leave BLANK locally to use the JSON file (server/data/db.json).
# Example: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# Solana network. Production MUST be mainnet-beta.
SOLANA_CLUSTER=mainnet-beta
SOLSCAN_CLUSTER=mainnet
# Use a PAID/production mainnet RPC (Helius, QuickNode, Triton, Alchemy). The public
# endpoint is heavily rate-limited and not suitable for production token verification.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# The pump.fun token contract address (mint) players must hold to be verified.
TOKEN_CA=8Ac6NUTzfk5FoC2VZ7fYkqFgZ6kBcKa9aaexAoAwpump
# Minimum token holding to be a verified player.
MIN_TOKENS=250000
# Token ticker/symbol shown in the UI (e.g. "Hold 250,000 $CS"). Exposed via /api/config.
TOKEN_TICKER=CS
# DEV ONLY: when true, every wallet is treated as verified (no RPC, no holdings
# required) so you can test without tokens. MUST be false/unset in production.
DISABLE_TOKEN_VERIFICATION=false
# How long a verification result is cached before a recheck (ms).
VERIFY_CACHE_MS=300000

# Treasury wallet — signs ALL creator reward settlements (+ player payouts).
# This is the ONLY wallet that pays creator rewards. base58 OR JSON byte array.
TREASURY_WALLET_PRIVATE_KEY=
# Dev/admin wallet (project ownership, buybacks, treasury funding). Separate from the
# treasury and NOT used for creator reward payouts.
CREATOR_REWARDS_WALLET_PRIVATE_KEY=

# Public keys. Derived from the private keys automatically if left blank.
TREASURY_PUBLIC_KEY=
CREATOR_REWARDS_PUBLIC_KEY=

# Anti-farm threshold profile. launch = strict (production); testing = relaxed
# (bypasses creator-self-farm + same-IP so payouts are easy to verify). Anti-farm
# stays ON in both modes. Default: launch.
#   launch : CREATOR_MIN_UNIQUE_PLAYERS=3 CREATOR_MIN_VERIFIED_KILLS=3 MIN_MATCH_MS=60000 PAIR_COOLDOWN_MS=60000 SPAWN_PROTECTION_MS=3000 PAIR_DAILY_CAP=10
#   testing: CREATOR_MIN_UNIQUE_PLAYERS=1 CREATOR_MIN_VERIFIED_KILLS=1 MIN_MATCH_MS=10000 PAIR_COOLDOWN_MS=10000
# Any of these can also be set explicitly to override the profile.
REWARD_MODE=launch

# Creator Reward Ledger economics (SOL — stored and paid in SOL, no USD). Settles automatically.
REWARD_PER_KILL=0.0025
REWARD_PER_UNIQUE=0.001
REWARD_PER_MINUTE=0.0002
DAILY_CREATOR_CAP=5
SETTLEMENT_MS=300000

# Multiplayer: max players per match room.
MAX_PLAYERS=16

# Frontend origin(s) for CORS + Socket.io, comma-separated (your Netlify/custom domain).
FRONTEND_URL=https://counterstrikepf.fun

# Protects POST /api/admin/force-settlement (Authorization: Bearer <ADMIN_SECRET>).
# Use a long random value. If unset, the admin endpoint is disabled (returns 403).
ADMIN_SECRET=
