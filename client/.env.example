# Copy to client/.env for local overrides. client/.env is gitignored.
# Only VITE_-prefixed vars are exposed to the frontend bundle.
#
# Leave BLANK for local dev — the Vite dev server proxies /api to the local backend.
# In production (Netlify), set this to your Render backend URL:
#   VITE_API_URL=https://bullstrike-api.onrender.com
VITE_API_URL=

# The $BS pump.fun token contract address shown in the UI (the backend is the source of
# truth for verification; this is display-only and falls back to /api/config).
VITE_TOKEN_CA=6XhuxmoBDgJTPQUjoxWSdsAQuoqBbGW7x3yeipcrpump

# The CA + pump.fun link are shown by default. Set to false to hide them and show a
# "SOON" placeholder pre-launch.
VITE_TOKEN_LIVE=true

# Token ticker/symbol shown in the UI (defaults to BS → rendered as "$BS").
VITE_TOKEN_TICKER=BS

# Social / action links (leave blank to hide).
VITE_PUMPFUN_URL=
VITE_TWITTER_URL=
