# Copy to client/.env for local overrides. client/.env is gitignored.
# Only VITE_-prefixed vars are exposed to the frontend bundle.
#
# Leave BLANK for local dev — the Vite dev server proxies /api to the local backend.
# In production (Netlify), set this to your Render backend URL:
#   VITE_API_URL=https://killmaps-api.onrender.com
VITE_API_URL=

# The pump.fun token contract address shown in the UI (the backend is the source of
# truth for verification; this is display-only and falls back to /api/config).
VITE_TOKEN_CA=C3RxH72uCos4VT2VZ6Y4LgthHy9k4uSwQGxiyxDBpump

# Social / action links (leave blank to hide).
VITE_PUMPFUN_URL=
VITE_TWITTER_URL=
